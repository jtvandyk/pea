# ── Azure Data Lake Storage Gen2 ──────────────────────────────────────────────
# Local dev: connection string (same format as Azure Blob Storage).
AZURE_STORAGE_CONNECTION_STRING=

# Azure Container Apps (managed identity — no connection string needed).
# Use the DFS endpoint (not the blob endpoint).
# e.g. https://myaccount.dfs.core.windows.net
AZURE_STORAGE_ACCOUNT_URL=

# ── LLM backend (all environments) ────────────────────────────────────────────
AZURE_FOUNDRY_API_KEY=
AZURE_OPENAI_ENDPOINT=    # e.g. https://<resource>.openai.azure.com/openai/v1

# ── Optional: news discovery sources ──────────────────────────────────────────
BBC_MONITORING_USER_NAME=
BBC_MONITORING_USER_PASSWORD=
WORLDNEWS_API_KEY=        # required for --source worldnews or --source all

# ── Optional: other LLM providers (not used in production) ────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Web dashboard (src/web/app.py) ────────────────────────────────────────────
# Required for the dashboard to trigger pipeline runs and tail logs.
# These are normally injected by infra/deploy.sh into the dashboard Container App
# from Key Vault or as plain env vars; document them here for local dev parity.
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
CONTAINER_APPS_JOB_NAME=                  # e.g. pea-daily
CONTAINER_APP_CONTAINER_NAME=pea-pipeline-job   # name inside the Container Apps Job spec
LOG_ANALYTICS_WORKSPACE_ID=               # workspace GUID for log-tail tab (optional)

# ADLS Gen2 layout used by the dashboard to list runs and read events.
# Must match the layout written by the pipeline's --upload-to flag.
BLOB_CONTAINER_NAME=pea-outputs           # ADLS filesystem name
BLOB_PREFIX=runs                          # path prefix under the filesystem

# Default value pre-filled into the dashboard's "upload-to" field when
# launching a manual run; e.g. az://pea-outputs/runs
DEFAULT_UPLOAD_TO=
