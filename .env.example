# GDELT rate limit: max 1 request / 5 seconds (free, no key required)
# Contact kalev.leetaru5@gmail.com for higher limits

# LLM API Keys (not needed for local Llama — see LLAMA_LOCAL_SETUP_M2_MAC.md)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
HUGGINGFACE_API_KEY=hf_...

# Ollama (local Llama) settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Inference settings
TEMPERATURE=0.1
MAX_TOKENS=1000
BATCH_SIZE=50

# Development
DEBUG=False
LOG_LEVEL=INFO
